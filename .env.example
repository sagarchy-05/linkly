# Database Configuration
POSTGRES_DB=curtli
DB_USERNAME=postgres
DB_PASSWORD=postgres
HOST_DB_PORT=5433

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
HOST_REDIS_PORT=6379

# App Configuration
CURTLI_BASE_URL=http://localhost:8080
HOST_APP_PORT=8080

# Async Analytics Thread Pool limits
ASYNC_CORE_POOL=8
ASYNC_MAX_POOL=32
ASYNC_QUEUE_CAPACITY=3000

# Redis Stream Consumer Tuning
STREAM_POLL_DELAY=1000
STREAM_BATCH_SIZE=1500
STREAM_BLOCK_MILLIS=250

# Bulk Shortening Rate limiting
RATE_LIMIT_BULK_MAX=5
RATE_LIMIT_BULK_MINUTES=15
BULK_BATCH_SIZE=20

# HikariCP (Postgres) Connection Pool
# Sized for AWS RDS free tier (db.t3.micro, ~112 max_connections, ~1GB RAM).
# Bump DB_POOL_MAX if you scale a single instance under cache-miss load.
DB_POOL_MAX=20
DB_POOL_MIN_IDLE=5
DB_POOL_CONN_TIMEOUT=10000      # ms — fail fast under saturation
DB_POOL_IDLE_TIMEOUT=600000     # 10 min — release unused connections
DB_POOL_MAX_LIFETIME=1800000    # 30 min — recycle before RDS may kill the connection
DB_POOL_LEAK_DETECTION=30000    # 30 s — log warning if a connection isn't returned